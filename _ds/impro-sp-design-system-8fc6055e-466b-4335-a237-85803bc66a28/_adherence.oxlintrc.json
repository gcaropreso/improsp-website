{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Affigere|Coolvetica|Coolvetica Condensed|Coolvetica Cram|Coolvetica Heavy Compressed|Libre Caslon Text|DuchaCompleta|TeAmoJessica|HitMePunk|HitMePunk-02|HitMePunk-03|HitMePunk-04|HitMePunk-05|HitMePunk-06|HitMePunk-07|HitMePunk-08|HitMePunk-09|HitMePunk-10|HitMePunk-11|HitMePunk-12|HitMePunk-13|HitMePunk-14))/i]",
        "message": "Font not provided by the design system. Available: Affigere, Coolvetica, Coolvetica Condensed, Coolvetica Cram, Coolvetica Heavy Compressed, Libre Caslon Text, DuchaCompleta, TeAmoJessica, HitMePunk, HitMePunk-02, HitMePunk-03, HitMePunk-04, HitMePunk-05, HitMePunk-06, HitMePunk-07, HitMePunk-08, HitMePunk-09, HitMePunk-10, HitMePunk-11, HitMePunk-12, HitMePunk-13, HitMePunk-14."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|rotate|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, rotate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|onClick|type|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, onClick, type, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|inverse|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'inverse' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|title|children|inverse|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: label, title, children, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|as|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: children, color, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:white|accent)$/]",
        "message": "<Divider> color must be one of 'white' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|name|note|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: number, name, note."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
